#!/usr/bin/env bash
# devstack helper — run from anywhere.
set -euo pipefail
STACK_DIR="$HOME/devstack"
cd "$STACK_DIR"

# normalize "8.2" or "82" -> "82"
nn()  { echo "${1//./}"; }
# normalize "8.2" or "82" -> service name "php82"
svc() { echo "php$(nn "$1")"; }

# scaffold a project folder + an nginx vhost, then reload nginx
scaffold_new() {
  local ver="${1:-}" name="${2:-}" mode="${3:-auto}"
  [ -n "$ver" ] && [ -n "$name" ] || { echo "usage: stack new <ver> <name> [laravel]"; exit 1; }
  local n; n="$(nn "$ver")"
  local conf="nginx/conf.d/${name}.local.conf"
  local proj="www/${name}"

  mkdir -p "$proj"
  # decide web root: laravel/public if requested or detected, else project root
  local root="/var/www/html/${name}"
  if [ "$mode" = "laravel" ] || [ -d "${proj}/public" ]; then
    root="/var/www/html/${name}/public"
  elif [ -z "$(ls -A "$proj" 2>/dev/null)" ]; then
    # empty plain project: drop a placeholder so the URL shows something
    printf '<?php phpinfo();\n' > "${proj}/index.php"
  fi

  if [ -e "$conf" ]; then
    echo "vhost $conf already exists — not overwriting"
  else
    cat > "$conf" <<EOF
# ${name} on PHP ${ver}  (generated by 'stack new'; *.local.conf is gitignored)
server {
    listen 80;
    server_name ${name}.${n}.test;
    return 301 https://\$host\$request_uri;
}
server {
    listen 443 ssl;
    server_name ${name}.${n}.test;

    ssl_certificate     /etc/nginx/certs/devstack.pem;
    ssl_certificate_key /etc/nginx/certs/devstack-key.pem;

    root ${root};
    index index.php index.html;

    location / { try_files \$uri \$uri/ /index.php?\$query_string; }
    location ~ \.php\$ {
        try_files \$uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)\$;
        fastcgi_pass php${n}:9000;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        fastcgi_param PATH_INFO \$fastcgi_path_info;
        fastcgi_param HTTPS \$https if_not_empty;
    }
}
EOF
    echo "created $conf  (root: ${root})"
  fi

  # reload nginx if it's running (ignore if the stack is down)
  if docker compose ps --status running nginx >/dev/null 2>&1 && \
     [ -n "$(docker compose ps -q nginx 2>/dev/null)" ]; then
    docker compose exec -T nginx nginx -t >/dev/null 2>&1 && \
    docker compose exec -T nginx nginx -s reload >/dev/null 2>&1 && echo "nginx reloaded"
  else
    echo "note: stack isn't running — 'stack up' to start it"
  fi
  echo "put code in ~/devstack/${proj}/  ->  https://${name}.${n}.test"
}

usage() {
  cat <<USAGE
devstack — multi-PHP dev environment

  stack new <ver> <name> [laravel]   scaffold a project folder + vhost
                                 e.g. stack new 8.2 myapp laravel
  stack up                       start everything
  stack down                     stop everything
  stack restart                  restart all containers
  stack rebuild                  rebuild PHP images + restart
  stack ps                       show container status
  stack logs [service]           tail logs (e.g. stack logs nginx)

  stack php <ver> <project> ...  run php in a project on that version
                                 e.g. stack php 8.2 info -v
  stack composer <ver> <proj> .. run composer for a project
                                 e.g. stack composer 7.4 shop install
  stack artisan <ver> <proj> ..  php artisan for a Laravel project
  stack sh <ver>                 shell into a PHP container
  stack mysql                    open a mysql client as root

Versions: 7.2 7.3 7.4 8.0 8.1 8.2 8.4
USAGE
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  new)      scaffold_new "${1:-}" "${2:-}" "${3:-auto}" ;;
  up)       docker compose up -d ;;
  down)     docker compose down ;;
  restart)  docker compose restart ;;
  rebuild)  docker compose up -d --build ;;
  ps)       docker compose ps ;;
  logs)     docker compose logs -f "$@" ;;
  php)      v="$1"; p="$2"; shift 2; docker compose exec -w "/var/www/html/$p" "$(svc "$v")" php "$@" ;;
  composer) v="$1"; p="$2"; shift 2; docker compose exec -w "/var/www/html/$p" "$(svc "$v")" composer "$@" ;;
  artisan)  v="$1"; p="$2"; shift 2; docker compose exec -w "/var/www/html/$p" "$(svc "$v")" php artisan "$@" ;;
  sh)       v="$1"; docker compose exec "$(svc "$v")" bash ;;
  mysql)    docker compose exec mysql sh -c 'exec mysql -uroot -p"$MYSQL_ROOT_PASSWORD"' ;;
  help|-h|--help) usage ;;
  *) echo "unknown command: $cmd"; echo; usage; exit 1 ;;
esac
