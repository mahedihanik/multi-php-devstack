# Persistent MySQL data — NEVER commit (contains real databases)
/data/

# TLS private key + cert (regenerate locally with mkcert)
/nginx/certs/

# Local secrets & logs
.env
*.log
*.err
.DS_Store

# IDE
.idea/
.vscode/

# Your own project vhosts: name them *.local.conf to keep them out of git.
# nginx still loads them (it includes *.conf). The php*.conf scaffolding and the
# .example template stay tracked.
/nginx/conf.d/*.local.conf

# Projects live here but are their own repos / not part of this scaffolding.
# Keep the folder + the sample 'info' project; ignore everything else.
/www/*
!/www/.gitkeep
!/www/info/
/www/info/.DS_Store
